# 生产环境配置示例
# 复制此文件为 .env.production 并修改相应配置

# ==================== API 配置 ====================
OPENAI_API_KEY=your_deepseek_api_key_here
OPENAI_API_BASE=https://api.deepseek.com

# HuggingFace 国内镜像配置
HF_ENDPOINT=https://hf-mirror.com

# ==================== 数据库配置 ====================
# 生产环境使用 PostgreSQL
DB_TYPE=postgresql
DB_USER=postgres
DB_PASSWORD=your_strong_password_here
DB_HOST=your_db_host  # 例如：localhost 或数据库服务器IP
DB_PORT=5432
DB_NAME=agent_db

# ==================== 服务配置 ====================
# 服务端口（可选，默认8000）
# PORT=8000

# 日志级别（可选）
# LOG_LEVEL=INFO

# ==================== 安全配置 ====================
# 建议生产环境配置：
# 1. 使用强密码
# 2. 限制数据库访问IP
# 3. 使用SSL连接数据库
# 4. 定期备份数据库
# 5. 使用环境变量管理敏感信息，不要提交到代码仓库
