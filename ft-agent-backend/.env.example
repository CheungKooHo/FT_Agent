# -*- coding: utf-8 -*-
# 支付集成环境变量示例
# 复制此文件为 .env 并填入实际配置

# ===== 支付宝配置 =====
# 支付宝应用 AppID
ALIPAY_APP_ID=2021000000000000

# 支付宝私钥（RSA2）
# 可以使用openssl生成：openssl genrsa -out app_private_key.pem 2048
# 然后转换：openssl rsa -in app_private_key.pem -outform PEM -pubout -out app_public_key.pem
ALIPAY_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END RSA PRIVATE KEY-----"

# 支付宝公钥
ALIPAY_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nYOUR_PUBLIC_KEY_HERE\n-----END PUBLIC KEY-----"

# 支付宝沙箱环境（开发测试用）
ALIPAY_SANDBOX=false

# ===== 微信支付配置 =====
# 微信支付应用 AppID
WECHAT_APP_ID=wx0000000000000000

# 微信支付商户号
WECHAT_MCH_ID=0000000000

# 微信支付 API 密钥
WECHAT_API_KEY=your_api_key_here

# 微信支付沙箱环境（开发测试用）
WECHAT_SANDBOX=false

# ===== 支付回调地址 =====
# 支付完成后第三方会回调此地址
# 注意：必须是外网可访问的地址
PAYMENT_CALLBACK_URL=https://your-domain.com/payment/callback
