# FT-Agent 环境变量配置
# 复制此文件为 .env 并修改配置

# ==================== 数据库 ====================
DB_TYPE=postgresql
DB_USER=ft_agent
DB_PASSWORD=ft_agent123
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agent_db

# ==================== AI 模型 ====================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE=https://api.deepseek.com
HF_ENDPOINT=https://hf-mirror.com

# ==================== 支付宝支付 ====================
ALIPAY_APP_ID=your_alipay_app_id_here
ALIPAY_SANDBOX=true
ALIPAY_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
your_alipay_private_key_here
-----END PRIVATE KEY-----"
ALIPAY_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
your_alipay_public_key_here
-----END PUBLIC KEY-----"

# ==================== 微信支付 ====================
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_KEY=

# ==================== 支付回调地址 ====================
PAYMENT_CALLBACK_URL=https://your-domain.com/payment/callback

# ==================== 邮件服务（可选）====================
SMTP_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your_email@example.com
SMTP_PASSWORD=your_email_password
SMTP_FROM_EMAIL=noreply@example.com

# ==================== Redis（可选）====================
REDIS_URL=redis://localhost:6379

# ==================== Webhook（可选）====================
WEBHOOK_ENABLED=false
WEBHOOK_URL=https://your-webhook.com/callback