# Docker 部署环境变量配置
# 复制此文件为 .env 并修改配置

# ==================== API 配置 ====================
# DeepSeek API Key（必填）
OPENAI_API_KEY=your_deepseek_api_key_here
OPENAI_API_BASE=https://api.deepseek.com

# ==================== 数据库配置 ====================
# 数据库密码（生产环境务必修改！）
DB_PASSWORD=your_strong_password_here

# ==================== 其他配置 ====================
# HuggingFace 镜像
HF_ENDPOINT=https://hf-mirror.com
